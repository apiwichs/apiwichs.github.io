---
import Layout from '../layouts/Layout.astro';
import Sidebar from '../components/Sidebar.astro';
import experience from '../data/experience.json';
import projects from '../data/projects.json';

const langSkills = [
  { name: 'C',               icon: '/assets/skills/c-logo.png' },
  { name: 'C++',             icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/cplusplus/cplusplus-original.svg' },
  { name: 'Python',          icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/python/python-original.svg' },
  { name: 'Verilog',         icon: '/assets/skills/verilog-logo.png' },
  { name: 'Java',            icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/java/java-original.svg' },
  { name: 'RISC-V Assembly', icon: '/assets/skills/assembly-logo.png' },
];

const toolSkills = [
  { name: 'Altium Designer', icon: '/assets/skills/altium-designer-logo.png' },
  { name: 'Git',             icon: 'https://cdn.jsdelivr.net/gh/devicons/devicon/icons/git/git-original.svg' },

];

const protoSkills = [
  { name: 'SPI',  sub: '4-wire synchronous',  svg: `<svg viewBox="0 0 48 48" class="proto-svg" role="img" aria-label="SPI: four-wire synchronous bus"><g fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 12 h4 V4 h4 V12 h4 V4 h4 V12 h4 V4 h4 V12 h4 V4 h4 V12 h4 V4 h4"/><path d="M4 20 h5 V28 h5 V20 h5 h5 V28 h5 V20 h5 V28 h5 h5"/><path d="M4 44 h5 V36 h5 V44 h5 V36 h5 h5 V44 h5 V36 h5 h5"/></g></svg>` },
  { name: 'I²C',  sub: '2-wire bus',          svg: `<svg viewBox="0 0 48 48" class="proto-svg" role="img" aria-label="I2C: two-wire bus"><g fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 17 h4 V7 h4 V17 h4 V7 h4 V17 h4 V7 h4 V17 h4 V7 h4 V17 h4 V7 h4"/><path d="M4 31 h5 V41 h5 V31 h5 h5 V41 h5 V31 h5 V41 h5 h5"/></g></svg>` },
  { name: 'UART', sub: '1-wire asynchronous', svg: `<svg viewBox="0 0 48 48" class="proto-svg" role="img" aria-label="UART: single-wire asynchronous frame"><g fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 16 h4 h4 V34 h4 V16 h4 V34 h4 V16 h4 h4 V34 h4 V16 h4 h4"/></g><g stroke="currentColor" stroke-width="1" stroke-dasharray="2 2" opacity="0.45"><path d="M12 8 V42"/><path d="M40 8 V42"/></g></svg>` },
];

---
<Layout title="Apiwich Sumeksri — Embedded Systems | UofT ECE">
  <Sidebar slot="sidebar" />

  <!-- ══════════════════════════ HERO ══════════════════════════ -->
  <section id="about" class="hero-section">
    <div class="hero-inner">

      <!-- ── LEFT: identity + bio ── -->
      <div class="hero-left">

        <div class="hero-label fade-up">
          <span class="hero-label-line"></span>
          <span class="hero-label-text">// about me</span>
        </div>

        <h1 class="hero-name fade-up">Apiwich Sumeksri</h1>

        <div class="hero-disciplines fade-up">
          <span class="disc-pill">Embedded Systems</span>
          <span class="disc-pill">FPGA</span>
          <span class="disc-pill">PCB Design</span>
          <span class="disc-pill">Analog &amp; Digital Circuit Design</span>
        </div>

        <p class="hero-bio fade-up">
          Third-year BASc Electrical and Computer Engineering student at the University of Toronto, working on PCB design, bare-metal firmware, Verilog, and analog and digital circuits.
        </p>

        <div class="hero-links fade-up">
          <a href="#projects" class="hero-btn-fill">View Projects</a>
          <a href="https://github.com/apiwichs" target="_blank" class="hero-link">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
            GitHub
          </a>
          <a href="https://linkedin.com/in/apiwichsumeksri" target="_blank" class="hero-link">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            LinkedIn
          </a>
          <a href="#contact" class="hero-link">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            Contact
          </a>
        </div>

      </div>

      <!-- ── RIGHT: info panel ── -->
      <div class="hero-right fade-up" data-delay="200">

        <!-- ADI callout — prominent card -->
        <div class="adi-card">
          <div class="adi-card-header">
            <span class="adi-dot"></span>
            <span class="adi-card-label">Current Role</span>
          </div>
          <div class="adi-card-co">Analog Devices Inc.</div>
          <div class="adi-card-role">Hardware Engineering Intern</div>
          <div class="adi-card-date">May 2026 – Present</div>
        </div>

        <!-- Quick facts grid -->
        <div class="hero-facts">
          <div class="fact-item">
            <div class="fact-label">Program</div>
            <div class="fact-val">BASc Electrical & Computer Engineering</div>
          </div>
          <div class="fact-item">
            <div class="fact-label">School</div>
            <div class="fact-val">University of Toronto</div>
          </div>
          <div class="fact-item">
            <div class="fact-label">Graduation</div>
            <div class="fact-val">June 2028</div>
          </div>
          <div class="fact-item">
            <div class="fact-label">Honours</div>
            <div class="fact-val fact-green">3× Dean's Honour List</div>
          </div>
        </div>


      </div>

    </div>
  </section>

  <!-- ══════════════════════════ EXPERIENCE ══════════════════════════ -->
  <section id="experience" class="page-section experience-section">
    <div class="section-inner">
      <div class="section-label-row">
        <span class="section-lbl">Experience</span>
        <div class="section-rule"></div>
      </div>

      <div class="exp-list">
        {experience.map((e, i) => (
          <article class="exp-card fade-up" data-delay={String(i * 100)}>

            <!-- Left col: company + meta -->
            <div class="exp-left">
              <div class={`exp-co${e.featured ? ' exp-co-adi' : ''}`}>
                {e.company}
              </div>
              <div class="exp-date">{e.date}</div>
              <div class="exp-loc">{e.location}</div>
            </div>

            <!-- Right col: role + bullets -->
            <div class="exp-right">
              <div class="exp-role">{e.role}</div>
              <ul class="exp-bullets">
                {e.bullets.map(b => (
                  <li set:html={b.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')} />
                ))}
              </ul>
            </div>

          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════ PROJECTS ══════════════════════════ -->
  <section id="projects" class="page-section projects-section">
    <div class="section-inner">
      <div class="section-label-row">
        <span class="section-lbl">Projects</span>
        <div class="section-rule"></div>
      </div>

      <div class="projects-grid">
        {projects.map((p, i) => (
          <article class="proj-card fade-up" data-delay={String(i * 120)}>
            <div class="card-carousel" data-index="0">
              {p.images.map((src, ii) => (
                (src.endsWith('.mp4') || src.endsWith('.webm')) ? (
                  <video class={`carousel-img${ii === 0 ? ' active' : ''}`} autoplay muted loop playsinline>
                    <source src={src} type="video/mp4" />
                  </video>
                ) : (
                  <img
                    src={src}
                    alt={`${p.title} image ${ii + 1}`}
                    class={`carousel-img${ii === 0 ? ' active' : ''}`}
                    onerror="this.style.display='none'"
                  />
                )
              ))}
              {p.images.length > 1 && (
                <Fragment>
                  <button class="carousel-btn carousel-prev" aria-label="Previous">&#8249;</button>
                  <button class="carousel-btn carousel-next" aria-label="Next">&#8250;</button>
                  <div class="carousel-dots">
                    {p.images.map((_, di) => (
                      <span class={`carousel-dot${di === 0 ? ' active' : ''}`}></span>
                    ))}
                  </div>
                </Fragment>
              )}
            </div>

            <div class="card-body">
              <div class="card-type-row">
                {p.type.split(' · ').map(t => (
                  <span class="card-type-pill">{t}</span>
                ))}
              </div>
              <h3 class="card-title">{p.title}</h3>
              <p class="card-desc">{p.desc}</p>
              <div class="card-tags">
                {p.tags.slice(0, 3).map(t => (
                  <span class="ctag">{t.label}</span>
                ))}
              </div>
              <a href={p.github} target="_blank" rel="noopener" class="github-btn">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
                View on GitHub
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════ EDUCATION ══════════════════════════ -->
  <section id="education" class="page-section education-section">
    <div class="section-inner">
      <div class="section-label-row">
        <span class="section-lbl">Education</span>
        <div class="section-rule"></div>
      </div>

      <div class="edu-card fade-up">
        <div class="edu-left">
          <div class="edu-inst">University of Toronto</div>
          <div class="edu-date">2024 – 2028</div>
        </div>
        <div class="edu-right">
          <div class="edu-deg">BASc Electrical & Computer Engineering</div>
          <div class="edu-honour">3× Dean's Honour List</div>
          <div class="edu-courses" style="margin-top:1rem">
            <span class="course-label">Completed —</span> Digital Systems · Computer Organization · Software Design
          </div>
          <div class="edu-courses" style="margin-top:0.35rem">
            <span class="course-label">Upcoming —</span> Microprocessors & Embedded Systems · Electronics · Signals & Systems
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════ SKILLS ══════════════════════════ -->
  <section id="skills" class="page-section skills-section">
    <div class="section-inner">
      <div class="section-label-row">
        <span class="section-lbl">Skills</span>
        <div class="section-rule"></div>
      </div>

      <div class="skill-boxes">

        <div class="skill-box fade-up">
          <h3 class="skill-box-title">Languages</h3>
          <div class="skill-box-divider"></div>
          <div class="sg-icons">
            {langSkills.map(s => (
              <div class="skill-chip">
                <img src={s.icon} alt={s.name} class="skill-icon" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
                <div class="skill-letter" style="display:none">{s.name}</div>
                <span class="skill-chip-label">{s.name}</span>
              </div>
            ))}
          </div>
        </div>

        <div class="skill-box fade-up" data-delay="80">
          <h3 class="skill-box-title">Software & Tools</h3>
          <div class="skill-box-divider"></div>
          <div class="sg-icons">
            {toolSkills.map(s => (
              <div class="skill-chip">
                {s.icon
                  ? <img src={s.icon} alt={s.name} class="skill-icon" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
                  : null}
                <div class="skill-letter" style={s.icon ? 'display:none' : ''}>{s.letter}</div>
                <span class="skill-chip-label">{s.name}</span>
              </div>
            ))}
          </div>
        </div>

        <div class="skill-box fade-up" data-delay="160">
          <h3 class="skill-box-title">Protocols</h3>
          <div class="skill-box-divider"></div>
          <div class="sg-icons">
            {protoSkills.map(s => (
              <div class="skill-chip proto-chip">
                <div class="proto-icon" set:html={s.svg} />
                <span class="skill-chip-label">{s.name}</span>
                <span class="proto-sub">{s.sub}</span>
              </div>
            ))}
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ══════════════════════════ CONTACT ══════════════════════════ -->
  <section id="contact" class="page-section contact-section">
    <div class="section-inner">
      <div class="section-label-row">
        <span class="section-lbl">Contact</span>
        <div class="section-rule"></div>
      </div>

      <div class="contact-layout fade-up">

        <!-- Left: intro + availability -->
        <div class="contact-left">
          <h2 class="contact-heading">Let's work together.</h2>
          <p class="contact-sub">
            Actively seeking PEY co-op roles in embedded systems, firmware,
            FPGA, and analog/mixed-signal hardware.
          </p>
          <div class="avail-badge">
            Seeking PEY Co-op · Starting Summer/Fall 2027
          </div>
        </div>

        <!-- Right: contact links -->
        <div class="c-links">
          <a href="mailto:apiwich.sumeksri@mail.utoronto.ca" class="c-link">
            <div class="c-icon">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </div>
            <div class="c-info">
              <span class="c-lbl">Email</span>
              <span class="c-val">apiwich.sumeksri@mail.utoronto.ca</span>
            </div>
          </a>
          <a href="https://linkedin.com/in/apiwichsumeksri" target="_blank" class="c-link">
            <div class="c-icon">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
            </div>
            <div class="c-info">
              <span class="c-lbl">LinkedIn</span>
              <span class="c-val">linkedin.com/in/apiwichsumeksri</span>
            </div>
          </a>
          <a href="https://github.com/apiwichs" target="_blank" class="c-link">
            <div class="c-icon">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
            </div>
            <div class="c-info">
              <span class="c-lbl">GitHub</span>
              <span class="c-val">github.com/apiwichs</span>
            </div>
          </a>
          <a href="tel:+14169303290" class="c-link">
            <div class="c-icon">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 1.27h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.8a16 16 0 0 0 6.29 6.29l.38-.86a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.27 16.92z"/></svg>
            </div>
            <div class="c-info">
              <span class="c-lbl">Phone</span>
              <span class="c-val">(416) 930-3290</span>
            </div>
          </a>
        </div>

      </div>
    </div>
  </section>

</Layout>

<style>
/* ══ SHARED ══ */
.page-section { position: relative; }
.section-inner { max-width: 980px; margin: 0 auto; padding: 4.5rem 2.5rem; }

/* Section label row — replaces chunky banners */
.section-label-row {
  display: flex;
  align-items: center;
  gap: 1.25rem;
  margin-bottom: 2.75rem;
}
.section-lbl {
  font-family: var(--sans);
  font-size: 1.5rem;
  font-weight: 700;
  letter-spacing: -0.02em;
  color: #0a1409;
  white-space: nowrap;
}
.section-rule {
  flex: 1;
  height: 1.5px;
  background: #e2e8e3;
}

/* ══ HERO ══ */
.hero-section {
  min-height: 100vh;
  display: flex;
  align-items: center;
  background: #ffffff;
  border-bottom: 1px solid #e2e8e3;
}
.hero-inner {
  max-width: 980px;
  margin: 0 auto;
  padding: 5rem 2.5rem 4rem;
  width: 100%;
  display: grid;
  grid-template-columns: 1fr 320px;
  gap: 5rem;
  align-items: start;
}

/* Left column */
.hero-left { display: flex; flex-direction: column; }

.hero-label {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  margin-bottom: 1.75rem;
}
.hero-label-line {
  width: 28px;
  height: 1.5px;
  background: #16a34a;
  flex-shrink: 0;
}
.hero-label-text {
  font-family: var(--mono);
  font-size: 0.68rem;
  font-weight: 500;
  color: #16a34a;
  letter-spacing: 0.12em;
}

.hero-name {
  font-size: clamp(2.4rem, 4.2vw, 3.4rem);
  font-weight: 700;
  color: #0a1409;
  letter-spacing: -0.03em;
  line-height: 1.05;
  margin-bottom: 1.25rem;
  white-space: nowrap;
}

.hero-disciplines {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0.4rem;
  margin-bottom: 2rem;
  max-width: 380px;
}
.disc-pill {
  font-family: var(--mono);
  font-size: 0.68rem;
  font-weight: 500;
  color: #1a4a2e;
  background: #eef7f1;
  border: 1px solid #c4dece;
  padding: 0.32rem 0.7rem;
  border-radius: 3px;
  white-space: nowrap;
  text-align: center;
  letter-spacing: 0.02em;
}

.hero-bio {
  font-size: 0.97rem;
  color: #2a3d2e;
  font-weight: 400;
  line-height: 1.85;
  max-width: 480px;
  margin-bottom: 2.25rem;
}


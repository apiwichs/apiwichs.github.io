<script>
document.querySelectorAll('.card-carousel').forEach(carousel => {
  const imgs = carousel.querySelectorAll('.carousel-img');
  const dots = carousel.querySelectorAll('.carousel-dot');
  const prev = carousel.querySelector('.carousel-prev');
  const next = carousel.querySelector('.carousel-next');

  function fitToTallest() {
    let maxH = 0;
    const carouselW = carousel.offsetWidth;
    imgs.forEach(img => {
      if (!img.naturalWidth) return;
      const ratio = img.naturalHeight / img.naturalWidth;
      const rendered = carouselW * ratio;
      if (rendered > maxH) maxH = rendered;
    });
    if (maxH > 0) imgs.forEach(img => img.style.height = maxH + 'px');
  }

  let loaded = 0;
  imgs.forEach(img => {
    if (img.complete) { loaded++; if (loaded === imgs.length) fitToTallest(); }
    else img.addEventListener('load', () => { loaded++; if (loaded === imgs.length) fitToTallest(); });
  });
  window.addEventListener('resize', fitToTallest);

  if (!prev || !next) return;
  let idx = 0;

  function updateButtons() {
    prev.style.opacity = idx === 0 ? '0.3' : '1';
    prev.style.pointerEvents = idx === 0 ? 'none' : 'auto';
    next.style.opacity = idx === imgs.length - 1 ? '0.3' : '1';
    next.style.pointerEvents = idx === imgs.length - 1 ? 'none' : 'auto';
  }

  function show(n) {
    if (n < 0 || n >= imgs.length) return;
    const current = imgs[idx];
    current.classList.remove('active');
    if (dots[idx]) dots[idx].classList.remove('active');
    if (current.tagName === 'VIDEO') current.pause();
    idx = n;
    const nextEl = imgs[idx];
    nextEl.classList.add('active');
    if (dots[idx]) dots[idx].classList.add('active');
    if (nextEl.tagName === 'VIDEO') nextEl.play();
    updateButtons();
  }

  updateButtons();
  prev.addEventListener('click', () => show(idx - 1));
  next.addEventListener('click', () => show(idx + 1));
  dots.forEach((dot, i) => dot.addEventListener('click', () => show(i)));
});
</script>

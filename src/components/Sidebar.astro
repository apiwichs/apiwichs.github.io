---
const links = [
  { href: '/#about',      label: 'About',      icon: `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>` },
  { href: '/#experience', label: 'Experience', icon: `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/></svg>` },
  { href: '/#projects',   label: 'Projects',   icon: `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>` },
  { href: '/#skills',     label: 'Skills',     icon: `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>` },
  { href: '/#education',  label: 'Education',  icon: `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>` },
  { href: '/#contact',    label: 'Contact',    icon: `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>` },
  { href: '/assets/ApiwichSumeksriResume.pdf', label: 'Résumé', external: true, icon: `<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>` },
];
---
<aside class="sidebar">

  <!-- Photo + name block -->
  <div class="sidebar-profile">
    <div class="sidebar-photo-wrap">
      <img
        src="/assets/photo.jpg"
        alt="Apiwich Sumeksri"
        class="sidebar-photo"
        onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
      />
      <div class="sidebar-photo-placeholder">A·S</div>
    </div>
    <div class="sidebar-name">Apiwich Sumeksri</div>
  </div>

  <div class="sidebar-divider"></div>

  <nav class="sidebar-nav">
    {links.map(l => (
      <a
        href={l.href}
        target={l.external ? '_blank' : undefined}
        rel={l.external ? 'noopener' : undefined}
        class={`sidebar-link${l.external ? ' sidebar-link-resume' : ''}`}
      >
        <span class="sidebar-icon" set:html={l.icon} />
        <span class="sidebar-label">{l.label}</span>
        {l.external && <span class="ext-arr">↗</span>}
      </a>
    ))}
  </nav>

</aside>

<style>
.sidebar {
  width: var(--sidebar-w);
  min-height: 100vh;
  position: fixed;
  top: 0; left: 0; bottom: 0;
  display: flex;
  flex-direction: column;
  align-items: stretch;
  padding: 0.75rem 0 1.5rem;
  z-index: 100;
  overflow-y: auto;
  background: #0e1512;
  border-right: 1px solid rgba(255,255,255,0.06);
}

/* Profile block */
.sidebar-profile {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.55rem;
  padding: 0 1rem 0.5rem;
}

.sidebar-photo-wrap {
  width: 131px;
  height: 131px;
  border-radius: 50%;
  overflow: hidden;
  border: 2px solid rgba(34,197,94,0.35);
  box-shadow: 0 0 0 4px rgba(34,197,94,0.08);
  flex-shrink: 0;
  background: #1a2e1e;
}
.sidebar-photo {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
.sidebar-photo-placeholder {
  display: none;
  width: 100%;
  height: 100%;
  align-items: center;
  justify-content: center;
  font-family: var(--mono);
  font-size: 0.82rem;
  font-weight: 700;
  color: #22c55e;
  letter-spacing: 0.1em;
}

.sidebar-name {
  font-family: var(--sans);
  font-size: 0.78rem;
  font-weight: 600;
  color: #d4e8d8;
  text-align: center;
  line-height: 1.3;
}

.sidebar-divider {
  height: 1px;
  background: rgba(255,255,255,0.06);
  margin: 0 0 1.1rem;
  flex-shrink: 0;
}

/* Nav */
.sidebar-nav {
  display: flex;
  flex-direction: column;
  gap: 0.08rem;
  padding: 0 0.6rem;
  flex: 1;
}

.sidebar-link {
  display: flex;
  align-items: center;
  gap: 0.7rem;
  padding: 0.62rem 0.85rem;
  border-radius: 6px;
  font-family: var(--sans);
  font-size: 0.82rem;
  font-weight: 400;
  color: #7a9a84;
  text-decoration: none;
  transition: all 0.16s;
  letter-spacing: 0.01em;
}
.sidebar-link:hover {
  background: rgba(34,197,94,0.08);
  color: #d4f0dc;
}
.sidebar-link:hover .sidebar-icon { color: #22c55e; }

.sidebar-link-resume {
  margin-top: auto;
  border: 1px solid rgba(34,197,94,0.2);
  color: #22c55e;
  font-family: var(--mono);
  font-size: 0.75rem;
  font-weight: 500;
  letter-spacing: 0.05em;
}
.sidebar-link-resume:hover {
  background: rgba(34,197,94,0.12);
  border-color: rgba(34,197,94,0.45);
  color: #4ade80;
}

.sidebar-icon {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  color: #4a6a54;
  transition: color 0.16s;
}
.sidebar-label { flex: 1; }
.ext-arr { font-size: 0.6rem; color: #4a6a54; }

/* Mobile */
@media (max-width: 768px) {
  .sidebar {
    width: 100%;
    min-height: auto;
    position: relative;
    flex-direction: row;
    align-items: center;
    flex-wrap: wrap;
    padding: 0.6rem 1rem;
    border-right: none;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }
  .sidebar-profile {
    flex-direction: row;
    gap: 0.6rem;
    padding: 0 1rem 0 0;
    border-bottom: none;
    border-right: 1px solid rgba(255,255,255,0.08);
  }
  .sidebar-photo-wrap { width: 32px; height: 32px; border-width: 1.5px; box-shadow: none; }
  .sidebar-name { font-size: 0.72rem; text-align: left; }
  .sidebar-subtitle { display: none; }
  .sidebar-divider { display: none; }
  .sidebar-nav { flex-direction: row; flex-wrap: wrap; gap: 0.15rem; padding: 0 0 0 0.75rem; flex: 1; }
  .sidebar-link { padding: 0.35rem 0.6rem; font-size: 0.75rem; border-radius: 4px; }
  .ext-arr { display: none; }
}
</style>

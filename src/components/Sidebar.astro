---
const pathname = Astro.url.pathname;
const links = [
  { href: '/#about',      label: 'About',      icon: `<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>`,      color: '#2a7a5a', bg: 'rgba(42,122,90,0.10)' },
  { href: '/#projects',   label: 'Projects',   icon: `<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`,               color: '#2a7a6a', bg: 'rgba(42,122,106,0.10)' },
  { href: '/#skills',     label: 'Skills',     icon: `<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>`,                                    color: '#2e7a72', bg: 'rgba(46,122,114,0.10)' },
  { href: '/#education',  label: 'Education',  icon: `<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>`, color: '#1e5a6a', bg: 'rgba(30,90,106,0.10)' },
  { href: '/#experience', label: 'Experience', icon: `<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/></svg>`, color: '#2a6a7a', bg: 'rgba(42,106,122,0.10)' },
  { href: '/#contact',    label: 'Contact',    icon: `<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>`, color: '#1e4a6a', bg: 'rgba(30,74,106,0.10)' },
  { href: '/assets/ApiwichSumeksriResume.pdf', label: 'Resume', external: true, icon: `<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>`, color: '#1a3a5a', bg: 'rgba(26,58,90,0.10)' },
];
---
<aside class="sidebar">
  <a href="/" class="sidebar-photo-wrap">
    <img src="/assets/photo.jpg" alt="Apiwich Sumeksri" class="sidebar-photo"
      onerror="this.style.display='none';this.nextElementSibling.style.display='flex'" />
    <div class="sidebar-photo-placeholder"><span>Add photo.jpg<br/>to public/assets/</span></div>
  </a>
  <div class="sidebar-name">Apiwich Sumeksri</div>
  <div class="sidebar-title">Electrical & Computer Engineering<br/>University of Toronto</div>
  <div class="sidebar-divider"></div>
  <nav class="sidebar-nav">
    {links.map(l => (
      <a href={l.href} target={l.external ? '_blank' : undefined} rel={l.external ? 'noopener' : undefined}
        class="sidebar-link" style={`--link-color:${l.color};--link-bg:${l.bg}`}>
        <span class="sidebar-icon" set:html={l.icon} />
        <span>{l.label}</span>
        {l.external && <span class="ext-arrow">↗</span>}
      </a>
    ))}
  </nav>
</aside>

<style>
.sidebar {
  width: var(--sidebar-w); min-height: 100vh; position: fixed;
  top: 0; left: 0; bottom: 0; display: flex; flex-direction: column;
  align-items: center; padding: 2rem 0 1.5rem; z-index: 100; overflow-y: auto;
  background: linear-gradient(180deg, #eef4f0 0%, #e4eeec 30%, #d8e8e8 60%, #cce0e4 85%, #c0d8e0 100%);
  border-right: 1px solid rgba(160,200,205,0.5);
}
.sidebar-photo-wrap {
  width: 190px;
  border-radius: 8px;
  overflow: hidden;
  flex-shrink: 0;
  border: 3px solid rgba(255,255,255,0.8);
  box-shadow: 0 2px 12px rgba(60,110,120,0.15);
  margin-bottom: 0.9rem;
  background: #c8dde0;
  text-decoration: none;
  display: block;
}
.sidebar-photo {
  width: 100%;
  height: auto;
  display: block;
  object-fit: contain;
}
.sidebar-photo-placeholder { display: none; width: 100%; height: 100%; align-items: center; justify-content: center; font-family: var(--mono); font-size: 0.5rem; line-height: 1.6; color: #6a8a8a; text-align: center; padding: 0.5rem; }
.sidebar-name { font-family: var(--sans); font-size: 1.05rem; font-weight: 700; color: #1a2e2a; text-align: center; line-height: 1.3; padding: 0 1rem; margin-bottom: 0.35rem; }
.sidebar-title { font-family: var(--sans); font-size: 0.82rem; font-weight: 400; color: #3a5a54; text-align: center; line-height: 1.6; padding: 0 1rem; }
.sidebar-divider { width: calc(100% - 2.5rem); height: 1px; background: rgba(130,175,180,0.4); margin: 1.2rem 0; flex-shrink: 0; }
.sidebar-nav { display: flex; flex-direction: column; width: 100%; padding: 0 0.65rem; gap: 0.12rem; }
.sidebar-link { display: flex; align-items: center; gap: 0.72rem; padding: 0.72rem 1rem; border-radius: 7px; font-family: var(--sans); font-size: 1rem; font-weight: 400; color: #2a4a48; text-decoration: none; transition: all 0.18s; }
.sidebar-link:hover { background: var(--link-bg); color: var(--link-color); }
.sidebar-link:hover .sidebar-icon { color: var(--link-color); }
.sidebar-icon { flex-shrink: 0; display: flex; align-items: center; color: #6a9090; transition: color 0.18s; }
.ext-arrow { font-size: 0.62rem; color: #8ab0b0; margin-left: auto; }
@media (max-width: 768px) {
  .sidebar { width: 100%; min-height: auto; position: relative; flex-direction: row; flex-wrap: wrap; padding: 0.75rem 1rem; border-right: none; border-bottom: 1px solid rgba(160,200,205,0.5); background: linear-gradient(90deg, #eef4f0 0%, #c0d8e0 100%); }
  .sidebar-photo-wrap, .sidebar-title, .sidebar-divider { display: none; }
  .sidebar-name { font-size: 0.82rem; margin-bottom: 0; padding: 0; }
  .sidebar-nav { flex-direction: row; flex-wrap: wrap; padding: 0; gap: 0.2rem; width: auto; margin-left: auto; }
  .sidebar-link { padding: 0.4rem 0.65rem; font-size: 0.78rem; border-radius: 5px; }
  .ext-arrow { display: none; }
}
</style>

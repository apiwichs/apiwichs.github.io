---
const pathname = Astro.url.pathname;
const links = [
  { href: '/',           label: 'Home'       },
  { href: '/projects',   label: 'Projects'   },
  { href: '/experience', label: 'Experience' },
  { href: '/about',      label: 'About'      },
  { href: '/contact',    label: 'Contact'    },
];
function isActive(href) {
  if (href === '/') return pathname === '/' || pathname === '';
  return pathname.startsWith(href);
}
---
<nav>
  <a href="/" class="nav-logo">Apiwich <span>Sumeksri</span></a>
  <ul class="nav-links">
    {links.map(l => (
      <li><a href={l.href} class={isActive(l.href) ? 'active' : ''}>{l.label}</a></li>
    ))}
  </ul>
  <a href="/assets/ApiwichSumeksriResume.pdf" target="_blank" class="nav-cta">Resume ↗</a>
</nav>

<style>
nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 200;
  height: 58px; padding: 0 2.5rem;
  display: flex; align-items: center; justify-content: space-between;
  background: rgba(255,255,255,0.96);
  backdrop-filter: blur(12px);
  border-bottom: 1px solid #e2e8e3;
}
.nav-logo { font-family: var(--sans); font-size: 0.95rem; font-weight: 700; color: var(--text-h); text-decoration: none; letter-spacing: -0.01em; }
.nav-logo span { color: var(--green); }
.nav-links { display: flex; gap: 2rem; list-style: none; }
.nav-links a { font-family: var(--sans); font-size: 0.85rem; font-weight: 400; color: var(--text-dim); text-decoration: none; transition: color 0.18s; }
.nav-links a:hover, .nav-links a.active { color: var(--text-h); }
.nav-links a.active { font-weight: 600; }
.nav-cta {
  font-family: var(--mono); font-size: 0.72rem;
  color: var(--green); border: 1.5px solid var(--green);
  padding: 0.32rem 0.9rem; text-decoration: none; letter-spacing: 0.04em;
  border-radius: 2px; transition: all 0.18s; font-weight: 500;
}
.nav-cta:hover { background: var(--green); color: #fff; }
@media (max-width: 780px) { nav { padding: 0 1.25rem; } .nav-links { display: none; } }
</style>
